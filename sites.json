{
  "sites": {
    "dekudeals": {
      "label": "Deku Deals",
      "domains": ["dekudeals.com", "www.dekudeals.com"],
      "capture_method": "cookies",
      "cookies": ["rack.session", "_deku_deals_session"],
      "output_path": "~/.mcp-credentials/dekudeals.json",
      "output_format": "cookie_jar",
      "color": "#7c3aed"
    },
    "pcexpress": {
      "label": "PC Express",
      "domains": ["pcexpress.ca", "realcanadiansuperstore.ca"],
      "capture_method": "bearer_intercept",
      "token_url_patterns": ["pcexpress.ca"],
      "oauth_url_patterns": ["oauth2", "update-token"],
      "extra_fields": {
        "cartId": { "source": "localStorage", "key": "lcl-cart-id-banner" }
      },
      "output_path": "~/justinritchie-mcp-servers/pcexpress-mcp-server/.env",
      "output_format": "dotenv",
      "credential_file": "~/.mcp-credentials/pcexpress.json",
      "dotenv_mapping": {
        "access_token": "PCEXPRESS_BEARER_TOKEN",
        "refresh_token": "PCEXPRESS_REFRESH_TOKEN",
        "cartId": "PCEXPRESS_CART_ID"
      },
      "dotenv_defaults": {
        "PCEXPRESS_CUSTOMER_ID": "",
        "PCEXPRESS_STORE_ID": "1517",
        "PCEXPRESS_BANNER": "superstore"
      },
      "color": "#e11d48"
    },
    "amazon": {
      "label": "Amazon",
      "domains": ["amazon.ca", "amazon.com", "amazon.co.uk"],
      "capture_method": "cookies",
      "required_cookies": ["at-*", "session-token"],
      "output_path": "~/justinritchie-mcp-servers/mcp-server-amazon/amazonCookies.json",
      "output_format": "cookie_editor",
      "color": "#f59e0b"
    },
    "aliexpress": {
      "label": "AliExpress",
      "domains": ["aliexpress.com", "www.aliexpress.com", "login.aliexpress.com"],
      "capture_method": "cookies",
      "output_path": "~/.mcp-credentials/aliexpress.json",
      "output_format": "cookie_jar",
      "color": "#ff4747"
    },
    "roll20": {
      "label": "Roll20",
      "domains": ["app.roll20.net", "roll20.net"],
      "capture_method": "firebase_idtoken",
      "extra_fields": {
        "database_url": { "source": "page", "via": "FIREBASE_ROOT" },
        "campaign_path": { "source": "window", "key": "campaign_storage_path" },
        "player_id": { "source": "window", "key": "d20_player_id" },
        "default_character_id": { "source": "page", "via": "controlled_character" }
      },
      "output_path": "~/.mcp-credentials/roll20.json",
      "output_format": "bearer_json",
      "credential_type": "roll20",
      "color": "#dc2626"
    }
  }
}
